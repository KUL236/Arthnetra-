# ============================================================
# ArthNetra — Environment Variables
# Copy to .env.local for local dev
# Add ALL of these to Netlify Dashboard → Site Settings → Env Vars
# ============================================================

# ── Supabase (public — safe to expose) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ── Market Data APIs (server-side only) ──────────────────────
TWELVE_DATA_API_KEY=your_key_here
DATA_GOV_API_KEY=your_key_here
FINNHUB_API_KEY=your_key_here
ALPHA_VANTAGE_API_KEY=your_key_here

# ── AI — Groq (server-side only) ─────────────────────────────
# Model used: llama-3.3-70b-versatile (latest as of 2025)
GROQ_API_KEY=your_key_here

# ── App URL (update after Netlify deployment) ─────────────────
NEXT_PUBLIC_APP_URL=https://your-app.netlify.app

# ============================================================
# SUPABASE SETUP CHECKLIST
# ============================================================
# 1. Authentication → Providers → Google: enable, add Client ID + Secret
# 2. Authentication → URL Configuration:
#      Site URL:          https://your-app.netlify.app
#      Redirect URLs:     https://your-app.netlify.app/auth/callback
#                         http://localhost:3000/auth/callback  (for local dev)
# 3. Authentication → Email:
#      Enable "Email OTP" (magic link / OTP)
#      Disable "Confirm email" if you want instant login after OTP
# 4. Run supabase-schema.sql in Supabase SQL Editor
# 5. Google Cloud Console → OAuth Credentials:
#      Authorized redirect URIs: https://<project>.supabase.co/auth/v1/callback
# ============================================================
